// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Batch {
  id          String   @id @default(cuid())
  name        String   @unique // e.g., "Batch 2010"
  slug        String   @unique
  year        Int      @unique // graduating year, used as primary identifier
  nickname    String?  // e.g., "The Lions"
  slogan      String?  // team slogan
  logoUrl     String?
  points      Int      @default(0)
  played      Int      @default(0)
  won         Int      @default(0)
  drawn       Int      @default(0)
  lost        Int      @default(0)
  goalsFor    Int      @default(0)
  goalsAgainst Int      @default(0)
  
  homeMatches Match[]  @relation("HomeTeam")
  awayMatches Match[]  @relation("AwayTeam")
  
  tournamentTeams TournamentTeam[]
  
  members     User[]   @relation("BatchMembers")
  followers   User[]   @relation("UserFollows")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([points(sort: Desc), goalsFor(sort: Desc)])
}

model Tournament {
  id          String   @id @default(cuid())
  name        String   @unique
  isActive    Boolean  @default(false)
  description String?  // about the tournament
  winPoints   Int      @default(3)
  drawPoints  Int      @default(1)
  lossPoints  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teams       TournamentTeam[]
  groups      TournamentGroup[]
  matches     Match[]
}

model TournamentGroup {
  id           String         @id @default(cuid())
  tournamentId String
  tournament   Tournament     @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  name         String         // e.g. "Group A"
  teams        TournamentTeam[]
  createdAt    DateTime       @default(now())

  @@unique([tournamentId, name])
}

model TournamentTeam {
  id           String           @id @default(cuid())
  tournamentId String
  tournament   Tournament       @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  batchId      String
  batch        Batch            @relation(fields: [batchId], references: [id], onDelete: Cascade)
  groupId      String?
  group        TournamentGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  points       Int        @default(0)
  played       Int        @default(0)
  won          Int        @default(0)
  drawn        Int        @default(0)
  lost         Int        @default(0)
  goalsFor     Int        @default(0)
  goalsAgainst Int        @default(0)

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([tournamentId, batchId])
  @@index([points(sort: Desc), goalsFor(sort: Desc)])
}


model Match {
  id          String   @id @default(cuid())
  date        DateTime
  status      MatchStatus @default(SCHEDULED)
  
  homeTeamId  String
  homeTeam    Batch    @relation("HomeTeam", fields: [homeTeamId], references: [id])
  homeScore   Int      @default(0)
  
  awayTeamId  String
  awayTeam    Batch    @relation("AwayTeam", fields: [awayTeamId], references: [id])
  awayScore   Int      @default(0)
  
  venue       String?
  isFeatured  Boolean  @default(false)
  
  tournamentId String?
  tournament   Tournament? @relation(fields: [tournamentId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  CANCELLED
}

model News {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String   @db.Text
  excerpt     String?
  imageUrl    String?
  publishedAt DateTime @default(now())
  isExclusive Boolean  @default(false)
  
  authorId    String?
  author      User?    @relation(fields: [authorId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Highlight {
  id          String   @id @default(cuid())
  title       String
  videoUrl    String
  thumbnailUrl String?
  description String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Post {
  id          String   @id @default(cuid())
  title       String?
  content     String   @db.Text
  status      PostStatus @default(PENDING)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  
  media       Media[]
  cheers      Cheer[]
  comments    Comment[]
  
  scope       PostScope @default(GLOBAL)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum PostScope {
  GLOBAL
  BATCH
}

model Media {
  id        String   @id @default(cuid())
  type      MediaType
  url       String
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

enum MediaType {
  IMAGE
  VIDEO
}

model Cheer {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

enum PostStatus {
  PENDING
  APPROVED
  REJECTED
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  message     String   @db.Text
  link        String?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, read])
}

model User {
  id            String    @id @default(cuid())
  firebaseId    String?   @unique
  password      String?
  name          String?
  email         String    @unique
  role          Role      @default(USER)
  image         String?
  occupation    String?
  workplace     String?
  phone         String?
  currentAddress String?
  permanentAddress String?
  
  batchId       String?
  batch         Batch?    @relation("BatchMembers", fields: [batchId], references: [id])
  
  followedBatches Batch[] @relation("UserFollows")
  posts         Post[]
  cheers        Cheer[]
  comments      Comment[]
  notifications Notification[]
  news          News[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  emailVerified DateTime?
  status        UserStatus @default(APPROVED)
  isPlayer      Boolean    @default(false)
  teamRole      String?
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}

enum Role {
  ADMIN
  CO_ADMIN
  BATCH_MANAGER
  USER
}
