generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Batch {
  id              String             @id @default(cuid())
  name            String             @unique
  slug            String             @unique
  logoUrl         String?
  points          Int                @default(0)
  played          Int                @default(0)
  won             Int                @default(0)
  drawn           Int                @default(0)
  lost            Int                @default(0)
  goalsFor        Int                @default(0)
  goalsAgainst    Int                @default(0)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  nickname        String?
  slogan          String?
  year            Int                @unique
  awayMatches     Match[]            @relation("AwayTeam")
  homeMatches     Match[]            @relation("HomeTeam")
  matchEvents     MatchEvent[]
  matchSquads     MatchSquadMember[]
  tournamentTeams TournamentTeam[]
  members         User[]             @relation("BatchMembers")
  followers       User[]             @relation("UserFollows")

  @@index([points(sort: Desc), goalsFor(sort: Desc)])
}

model Tournament {
  id          String            @id @default(cuid())
  name        String            @unique
  isActive    Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  description String?
  drawPoints  Int               @default(1)
  lossPoints  Int               @default(0)
  winPoints   Int               @default(3)
  matches     Match[]
  groups      TournamentGroup[]
  teams       TournamentTeam[]
  awards      SeasonAward[]
  ratings     AwardRating[]
}

model TournamentGroup {
  id           String           @id @default(cuid())
  tournamentId String
  name         String
  createdAt    DateTime         @default(now())
  tournament   Tournament       @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teams        TournamentTeam[]

  @@unique([tournamentId, name])
}

model TournamentTeam {
  id           String           @id @default(cuid())
  tournamentId String
  batchId      String
  points       Int              @default(0)
  played       Int              @default(0)
  won          Int              @default(0)
  drawn        Int              @default(0)
  lost         Int              @default(0)
  goalsFor     Int              @default(0)
  goalsAgainst Int              @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  groupId      String?
  batch        Batch            @relation(fields: [batchId], references: [id], onDelete: Cascade)
  group        TournamentGroup? @relation(fields: [groupId], references: [id])
  tournament   Tournament       @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, batchId])
  @@index([points(sort: Desc), goalsFor(sort: Desc)])
}

model Match {
  id                String             @id @default(cuid())
  date              DateTime
  status            MatchStatus        @default(SCHEDULED)
  homeTeamId        String
  homeScore         Int                @default(0)
  awayTeamId        String
  awayScore         Int                @default(0)
  venue             String?
  isFeatured        Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  tournamentId      String?
  awayCorners       Int                @default(0)
  awayOffsides      Int                @default(0)
  awayPossession    Int                @default(50)
  awayShots         Int                @default(0)
  awayShotsOnTarget Int                @default(0)
  clockRunning      Boolean            @default(false)
  clockStartedAt    DateTime?
  currentMinute     Int                @default(0)
  homeCorners       Int                @default(0)
  homeOffsides      Int                @default(0)
  homePossession    Int                @default(50)
  homeShots         Int                @default(0)
  homeShotsOnTarget Int                @default(0)
  injuryTime        Int                @default(0)
  awayPenaltyScore  Int                @default(0)
  homePenaltyScore  Int                @default(0)
  matchPeriod       MatchPeriod        @default(PRE_MATCH)
  penaltySequence   Json?
  awayCleanSheet    Boolean            @default(false)
  homeCleanSheet    Boolean            @default(false)
  manOfTheMatchId   String?
  awayTeam          Batch              @relation("AwayTeam", fields: [awayTeamId], references: [id])
  homeTeam          Batch              @relation("HomeTeam", fields: [homeTeamId], references: [id])
  manOfTheMatch     User?              @relation("ManOfTheMatch", fields: [manOfTheMatchId], references: [id])
  tournament        Tournament?        @relation(fields: [tournamentId], references: [id])
  events            MatchEvent[]
  matchSquads       MatchSquadMember[]
}

model News {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String
  excerpt     String?
  imageUrl    String?
  publishedAt DateTime @default(now())
  isExclusive Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  authorId    String?
  author      User?    @relation(fields: [authorId], references: [id])
}

model Highlight {
  id           String   @id @default(cuid())
  title        String
  videoUrl     String
  thumbnailUrl String?
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Post {
  id        String     @id @default(cuid())
  title     String?
  content   String
  status    PostStatus @default(PENDING)
  authorId  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  scope     PostScope  @default(GLOBAL)
  cheers    Cheer[]
  comments  Comment[]
  media     Media[]
  author    User       @relation(fields: [authorId], references: [id])
}

model Media {
  id        String    @id @default(cuid())
  type      MediaType
  url       String
  postId    String
  createdAt DateTime  @default(now())
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Cheer {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  postId    String
  authorId  String
  createdAt DateTime @default(now())
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model User {
  id                  String             @id @default(cuid())
  firebaseId          String?            @unique
  name                String?
  email               String             @unique
  role                Role               @default(USER)
  image               String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  password            String?
  batchId             String?
  occupation          String?
  phone               String?
  currentAddress      String?
  permanentAddress    String?
  workplace           String?
  emailVerified       DateTime?
  status              UserStatus         @default(APPROVED)
  isPlayer            Boolean            @default(false)
  teamRole            String?
  teamDesignation     String?
  isCommitteeMember   Boolean            @default(false)
  committeeRole       String?
  isVolunteer         Boolean            @default(false)
  cheers              Cheer[]
  comments            Comment[]
  manOfTheMatchAwards Match[]            @relation("ManOfTheMatch")
  matchAssists        MatchEvent[]       @relation("EventAssist")
  matchEvents         MatchEvent[]       @relation("EventPlayer")
  matchSubsIn         MatchEvent[]       @relation("EventPlayerIn")
  matchParticipations MatchSquadMember[]
  news                News[]
  notifications       Notification[]
  posts               Post[]
  captainedAwards     SeasonAward[]      @relation("AwardCaptain")
  coachedAwards       SeasonAward[]      @relation("AwardCoach")
  batch               Batch?             @relation("BatchMembers", fields: [batchId], references: [id])
  awardParticipations SeasonAward[]      @relation("AwardPlayers")
  followedBatches     Batch[]            @relation("UserFollows")
  awardRatings        AwardRating[]      @relation("PlayerRatings")
  judgeVotes          AwardRating[]      @relation("JudgeVotes")
}

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}

model MatchSquadMember {
  id        String            @id @default(cuid())
  matchId   String
  batchId   String
  userId    String
  status    MatchPlayerStatus @default(STARTER)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  batch     Batch             @relation(fields: [batchId], references: [id], onDelete: Cascade)
  match     Match             @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
}

model MatchEvent {
  id         String         @id @default(cuid())
  matchId    String
  type       MatchEventType
  minute     Int
  extraTime  Int?
  playerId   String?
  playerInId String?
  assistId   String?
  teamId     String?
  note       String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  assist     User?          @relation("EventAssist", fields: [assistId], references: [id])
  match      Match          @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player     User?          @relation("EventPlayer", fields: [playerId], references: [id])
  playerIn   User?          @relation("EventPlayerIn", fields: [playerInId], references: [id])
  team       Batch?         @relation(fields: [teamId], references: [id])
}

model SeasonAward {
  id          String   @id @default(cuid())
  category    String
  title       String
  description String?
  tournamentId String
  coachId     String?
  captainId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tournament  Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  captain     User?    @relation("AwardCaptain", fields: [captainId], references: [id])
  coach       User?    @relation("AwardCoach", fields: [coachId], references: [id])
  players     User[]   @relation("AwardPlayers")

  @@unique([category, tournamentId])
}

model AwardRating {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  category     String     // e.g., "BEST_PLAYER", "BEST_GOALKEEPER", "TOP_SCORER"
  playerId     String
  player       User       @relation("PlayerRatings", fields: [playerId], references: [id], onDelete: Cascade)
  judgeId      String
  judge        User       @relation("JudgeVotes", fields: [judgeId], references: [id], onDelete: Cascade)
  rating       Int        // 1-10
  comment      String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([tournamentId, category, playerId, judgeId])
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  CANCELLED
}

enum MatchPeriod {
  PRE_MATCH
  FIRST_HALF
  HALF_TIME
  SECOND_HALF
  FULL_TIME
  EXTRA_TIME_1
  EXTRA_TIME_HALF_TIME
  EXTRA_TIME_2
  PENALTIES
  FINISHED
}

enum PostScope {
  GLOBAL
  BATCH
}

enum MediaType {
  IMAGE
  VIDEO
}

enum PostStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Role {
  ADMIN
  CO_ADMIN
  USER
  BATCH_MANAGER
  SCORER
}

enum MatchPlayerStatus {
  STARTER
  SUBSTITUTE
}

enum MatchEventType {
  GOAL
  YELLOW_CARD
  RED_CARD
  SUBSTITUTION
  VAR
  PERIOD_START
  PERIOD_END
  COMMENTARY
}
